# ========== 环境变量 ==========
.env

# ========== Python ==========
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/

# ========== IDE ==========
.idea/
.vscode/
*.swp
*.swo

# ========== OS ==========
.DS_Store
Thumbs.db

# ========== Docker ==========
.dockerignore

# ========== AutoIPTV 运行时生成文件 ==========
# 用户配置（包含真实凭据、内网 IP、MAC 地址等敏感信息）
static/config.json

# 频道列表（包含内网 IGMP/RTSP 地址）
static/channels.txt
static/channels_rtsp.txt

# 日志（可能包含 Token 和内部 IP）
static/relogs.txt

# 同步状态
static/sync_info.json

# EPG 缓存
static/epg_cache.json
static/epg.xml
