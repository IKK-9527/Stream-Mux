# ============================================
# AutoIPTV 配置模板
# ============================================
# 使用方式: 复制此文件为 .env，填入真实值后启动
#    cp .env.example .env
#
# 所有配置项也可通过 Web 界面 (系统配置页面) 设置，
# 会保存到 static/config.json（已在 .gitignore 中排除）
# ============================================

# ---------- 必需配置 ----------
# 机顶盒所属用户 ID（从机顶盒或运营商获取）
USER_ID=

# 机顶盒序列号/设备 ID
STBID=

# ---------- 网络配置 ----------
# EPG 门户基础地址
BASE_URL=http://172.23.34.169:8080

# EPG 节目单服务器地址
EPG_HOST=http://172.23.35.201:8080

# 机顶盒 IP 地址（用于 Authenticator 计算）
STB_IP=

# UDPXY 转发地址（igmp → http）
UDPXY=http://10.10.10.1:7088/udp/

# ---------- Authenticator 配置 ----------
# 方式一：静态 Authenticator（从机顶盒抓包获取）
Authenticator=

# 方式二：动态生成（推荐，自动计算 Authenticator）
# MAC 地址（格式: 00:11:22:33:44:55）
MAC=
# 8 位加密密钥（需从机顶盒获取或爆破）
ENCRYPT_KEY=
# 机顶盒型号
STB_TYPE=B860AV1.1-T2

# ---------- 高级配置 ----------
# EAS 认证服务器域名
EAS_DOMAIN=epg.itv.cq.cn
# 内网 DNS 服务器（用于解析 EAS_DOMAIN）
DNS_SERVERS=172.16.5.144,172.16.5.145
# EAS 固定 IP（非空则跳过 DNS 解析直接使用）
EAS_IP=

# ---------- Flask ----------
# Flask secret key（用于 flash 消息加密，建议改为随机字符串）
SECRET_KEY=change-me-to-a-random-string

# ---------- EAS 会话参数 ----------
# EAS 服务器内部通信 IP（用于会话初始化参数）
EAS_SESSION_IP=172.16.5.214
# EAS STB 类型（用于会话认证）
EAS_STB_TYPE=EC2106V1H_pub
